{
	"name": "@tupper/deepagents",
	"version": "0.1.1",
	"description": "Tupper sandbox backend for LangChain deepagents.",
	"keywords": [
		"tupper",
		"sandbox",
		"deepagents",
		"langchain",
		"ai-agents",
		"agent-sandbox",
		"code-interpreter"
	],
	"license": "MIT",
	"author": "Tupper contributors",
	"homepage": "https://github.com/lightbearco/tupper/tree/main/packages/deepagents#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lightbearco/tupper.git",
		"directory": "packages/deepagents"
	},
	"bugs": {
		"url": "https://github.com/lightbearco/tupper/issues"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"check:publish": "publint --strict && attw --pack ."
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@tupper/sdk": "workspace:*"
	},
	"peerDependencies": {
		"deepagents": ">=1.10 <2"
	},
	"devDependencies": {
		"deepagents": "^1.10.5"
	},
	"publishConfig": {
		"access": "public"
	}
}
