{
	"name": "@tupper/container",
	"version": "0.1.0",
	"description": "Apple Containers backend for Tupper.",
	"keywords": [
		"tupper",
		"sandbox",
		"sandboxing",
		"apple-container",
		"apple-containers",
		"macos",
		"containers",
		"ai-agents",
		"agent-sandbox",
		"code-execution",
		"code-interpreter",
		"e2b-alternative",
		"llm"
	],
	"license": "MIT",
	"author": "Tupper contributors",
	"homepage": "https://github.com/lightbearco/tupper/tree/main/packages/container#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lightbearco/tupper.git",
		"directory": "packages/container"
	},
	"bugs": {
		"url": "https://github.com/lightbearco/tupper/issues"
	},
	"type": "module",
	"sideEffects": true,
	"os": [
		"darwin"
	],
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"check:publish": "publint --strict && attw --pack ."
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@tupper/core": "workspace:*"
	},
	"publishConfig": {
		"access": "public"
	}
}
