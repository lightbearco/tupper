{
	"name": "@tupper/api",
	"version": "0.1.1",
	"description": "HTTP API for Tupper sandboxes, built on Hono.",
	"keywords": [
		"tupper",
		"sandbox",
		"sandboxing",
		"api",
		"http",
		"hono",
		"rest",
		"ai-agents",
		"agent-sandbox",
		"code-execution",
		"self-hosted"
	],
	"license": "MIT",
	"author": "Tupper contributors",
	"homepage": "https://github.com/lightbearco/tupper/tree/main/packages/api#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lightbearco/tupper.git",
		"directory": "packages/api"
	},
	"bugs": {
		"url": "https://github.com/lightbearco/tupper/issues"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"bin": {
		"tupper-api": "./dist/server.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"start": "node ./dist/server.mjs",
		"typecheck": "tsc --noEmit",
		"check:publish": "publint --strict && attw --pack ."
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@tupper/core": "workspace:*",
		"@tupper/sdk": "workspace:*",
		"hono": "^4.6.14",
		"zod": "^4.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
